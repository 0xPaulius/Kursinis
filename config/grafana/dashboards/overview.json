{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Logų srautas per laiką",
      "description": "Visų logų kiekis per laiko intervalą",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"syslog\"} [1m]))",
          "legendFormat": "Visi logai",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({job=\"security\"} [1m]))",
          "legendFormat": "Saugumo logai",
          "refId": "B"
        },
        {
          "expr": "sum(count_over_time({job=\"errors\"} [1m]))",
          "legendFormat": "Klaidos",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false,
            "pointSize": 5
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Saugumo logai" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Klaidos" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "title": "Logai pagal severity",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum by (severity) (count_over_time({job=\"syslog\"} | severity != \"\" [$__range]))",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Top 10 šaltinių (hosts)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "topk(10, sum by (host) (count_over_time({job=\"syslog\"} | host != \"\" [$__range])))",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Top programos",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "topk(10, sum by (program) (count_over_time({job=\"syslog\"} | program != \"\" [$__range])))",
          "legendFormat": "{{program}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "SSH nesėkmingi prisijungimai",
      "description": "Failed SSH login bandymai per laiką",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum by (host) (count_over_time({job=\"syslog\"} |= \"Failed password\" [5m]))",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50 },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "Firewall DROP/REJECT",
      "description": "Blokuoti paketai ugniasienėje",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"syslog\"} |~ \"DROP|REJECT\" [5m]))",
          "legendFormat": "Blokuoti paketai",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 30 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "title": "Saugumo žurnalai (Live)",
      "description": "Realaus laiko saugumo logų srautas",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{job=\"security\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["syslog", "security", "anomaly"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Europe/Vilnius",
  "title": "Žurnalų analizė - Apžvalga",
  "uid": "log-analysis-overview",
  "version": 1
}
