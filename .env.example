# Compose projekto pavadinimas — uzfiksuojame, kad volume vardai
# nepriklausyty nuo klone direktorijos pavadinimo (seed_demo.sh remiasi `kursinis_*`).
COMPOSE_PROJECT_NAME=kursinis

# Grafana admin slaptažodis
# Sukurkite .env failą su realia reikšme prieš `docker compose up`.
# Pavyzdys: GF_SECURITY_ADMIN_PASSWORD=keiskite-mane
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME
